rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.admin == true
        || (
          exists(/databases/$(database)/documents/users/$(request.auth.uid))
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "administrator"
        )
      );
    }

    function isListingPublic(listingData) {
      return (listingData.reviewStatus == "approved"
        || !listingData.keys().hasAny(["reviewStatus"]))
        && listingData.status != "removed";
    }

    function isSampleAdminBootstrap() {
      return request.resource.data.role == "administrator"
        && request.resource.data.email == "aa@hh.com"
        && request.resource.data.firstName == "Annie"
        && request.resource.data.lastName == "Admin";
    }

    function isLandlordForListing(listingId) {
      return isSignedIn()
        && get(/databases/$(database)/documents/listings/$(listingId)).data.landlordId == request.auth.uid;
    }

    function listingBelongsToLandlord(listingId, landlordId) {
      return listingId != null
        && landlordId != null
        && get(/databases/$(database)/documents/listings/$(listingId)).data.landlordId == landlordId;
    }

    function isUniqueViewIncrement() {
      let currentViews = resource.data.uniqueViewCount is int ? resource.data.uniqueViewCount : 0;
      let changedKeys = request.resource.data.diff(resource.data).changedKeys();
      return changedKeys.hasOnly(["uniqueViewCount"])
        && request.resource.data.uniqueViewCount == currentViews + 1;
    }

    // Raw analytics events: clients can write, but never read.
    match /events/{eventId} {
      allow create: if isSignedIn();
      allow read, update, delete: if false;
    }

    // Daily listing stats: landlords can read and write their own stats (e.g. seed data when using emulator without Functions).
    match /listing_daily_stats/{listingId} {
      match /days/{date} {
        allow read, create, update: if isLandlordForListing(listingId);
        allow delete: if false;
      }
    }

    match /listings/{listingId} {
      allow read: if isListingPublic(resource.data)
        || isAdmin()
        || (isSignedIn() && resource.data.landlordId == request.auth.uid);
      allow create: if isSignedIn()
        && request.resource.data.landlordId == request.auth.uid
        && request.resource.data.reviewStatus == "under_review";
      allow update: if isSignedIn() && (
          isAdmin()
          || isUniqueViewIncrement()
          || (
            isLandlordForListing(listingId)
            && request.resource.data.reviewStatus != "approved"
            && request.resource.data.reviewStatus != "rejected"
            && request.resource.data.reviewStatus != "taken_down"
          )
        );
      allow delete: if isSignedIn() && (isLandlordForListing(listingId) || isAdmin());

      match /views/{viewerId} {
        allow read: if isSignedIn()
          && (request.auth.uid == viewerId || isLandlordForListing(listingId));
        allow create: if isSignedIn()
          && request.auth.uid == viewerId
          && request.resource.data.viewerId == viewerId;
        allow update, delete: if false;
      }
    }

    match /users/{userId} {
      allow read: if isAdmin() || (isSignedIn()
        && (request.auth.uid == userId || resource.data.role == "landlord"));
      allow create: if isSignedIn()
        && request.auth.uid == userId
        && (
          request.resource.data.role in ["tenant", "landlord"]
          || isSampleAdminBootstrap()
        );
      allow update: if isAdmin() || (
          isSignedIn()
          && request.auth.uid == userId
          && !request.resource.data.diff(resource.data).changedKeys().hasAny(["role", "isBanned", "bannedAt", "bannedBy", "banReason"])
        );
      allow delete: if false;

      match /saved_listings/{listingId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    match /verifications/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && request.auth.uid == userId;
      allow delete: if false;
    }

    function isChatParticipant(chatData) {
      return isSignedIn()
        && (chatData.tenantId == request.auth.uid || chatData.landlordId == request.auth.uid);
    }

    match /chats/{chatId} {
      allow create: if isSignedIn()
        && request.resource.data.tenantId == request.auth.uid
        && request.resource.data.landlordId != null
        && request.resource.data.listingId != null
        && listingBelongsToLandlord(request.resource.data.listingId, request.resource.data.landlordId);
      allow read, update: if isSignedIn()
        && (resource.data.tenantId == request.auth.uid || resource.data.landlordId == request.auth.uid);
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isSignedIn()
          && (get(/databases/$(database)/documents/chats/$(chatId)).data.tenantId == request.auth.uid
              || get(/databases/$(database)/documents/chats/$(chatId)).data.landlordId == request.auth.uid);
        allow create: if isSignedIn()
          && (get(/databases/$(database)/documents/chats/$(chatId)).data.tenantId == request.auth.uid
              || get(/databases/$(database)/documents/chats/$(chatId)).data.landlordId == request.auth.uid)
          && request.resource.data.senderId == request.auth.uid;
        allow update, delete: if false;
      }
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn()
        && (
          request.resource.data.userId == request.auth.uid
          || (request.resource.data.listingId != null && isLandlordForListing(request.resource.data.listingId))
        );
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    match /aiChats/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create: if false;
      allow update, delete: if false;

      match /messages/{messageId} {
        allow read: if isSignedIn() && request.auth.uid == userId;
        allow create: if isSignedIn()
          && request.auth.uid == userId
          && request.resource.data.userId == userId;
        allow update, delete: if false;
      }
    }

    match /contracts/{contractId} {
      allow read: if isSignedIn()
        && (
          (resource.data.keys().hasAll(["tenantId", "landlordId"])
            && (resource.data.tenantId == request.auth.uid || resource.data.landlordId == request.auth.uid))
          || (
            resource.data.chatId != null
            && isChatParticipant(get(/databases/$(database)/documents/chats/$(resource.data.chatId)).data)
          )
        );
      allow create: if isSignedIn()
        && request.auth.uid == request.resource.data.landlordId
        && request.resource.data.listingId != null
        && request.resource.data.chatId != null
        && request.resource.data.tenantId is string
        && request.resource.data.tenantId.size() > 0
        && listingBelongsToLandlord(request.resource.data.listingId, request.resource.data.landlordId)
        && get(/databases/$(database)/documents/chats/$(request.resource.data.chatId)).data.listingId == request.resource.data.listingId;
      allow update: if isSignedIn()
        && resource.data.keys().hasAll(["tenantId", "landlordId"])
        && (resource.data.tenantId == request.auth.uid || resource.data.landlordId == request.auth.uid)
        && listingBelongsToLandlord(resource.data.listingId, resource.data.landlordId);
      allow delete: if false;
    }

    match /issues/{issueId} {
      allow read: if isSignedIn()
        && (resource.data.tenantId == request.auth.uid || resource.data.landlordId == request.auth.uid);
      allow create: if isSignedIn()
        && request.resource.data.tenantId == request.auth.uid
        && request.resource.data.contractId != null
        && request.resource.data.listingId != null
        && request.resource.data.chatId != null
        && get(/databases/$(database)/documents/contracts/$(request.resource.data.contractId)).data.listingId == request.resource.data.listingId
        && get(/databases/$(database)/documents/contracts/$(request.resource.data.contractId)).data.landlordId == request.resource.data.landlordId
        && get(/databases/$(database)/documents/chats/$(request.resource.data.chatId)).data.listingId == request.resource.data.listingId;
      allow update: if isSignedIn()
        && (resource.data.tenantId == request.auth.uid || resource.data.landlordId == request.auth.uid);
      allow delete: if false;
    }

    match /tenancies/{tenancyId} {
      allow read: if isSignedIn()
        && (resource.data.tenantId == request.auth.uid || resource.data.landlordId == request.auth.uid);
      allow create, update: if isSignedIn()
        && (request.resource.data.tenantId == request.auth.uid || request.resource.data.landlordId == request.auth.uid)
        && listingBelongsToLandlord(request.resource.data.listingId, request.resource.data.landlordId)
        && request.resource.data.contractId != null
        && get(/databases/$(database)/documents/contracts/$(request.resource.data.contractId)).data.listingId == request.resource.data.listingId;
      allow delete: if false;
    }

    match /rentals/{rentalId} {
      allow read: if isSignedIn()
        && (resource.data.tenantId == request.auth.uid || resource.data.landlordId == request.auth.uid);
      allow create, update, delete: if false;
    }
  }
}
