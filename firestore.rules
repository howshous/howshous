rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        (request.auth.token.keys().hasAll(['admin']) && request.auth.token.admin == true)
        || (
          exists(/databases/$(database)/documents/users/$(request.auth.uid))
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "administrator"
        )
      );
    }

    function isBanned() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.keys().hasAny(["isBanned"])
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isBanned == true;
    }

    // Tenants browse/search: read active listings (gender + slot filtering is applied in the app).
    function isListingReadableByTenant(listingData) {
      return listingData.status == "active";
    }

    function isSampleAdminBootstrap() {
      return request.resource.data.keys().hasAll(["role", "email", "firstName", "lastName"])
        && request.resource.data.role == "administrator"
        && request.resource.data.email == "aa@hh.com"
        && request.resource.data.firstName == "Annie"
        && request.resource.data.lastName == "Admin";
    }

    function isLandlordForListing(listingId) {
      return isSignedIn()
        && get(/databases/$(database)/documents/listings/$(listingId)).data.landlordId == request.auth.uid;
    }

    function listingBelongsToLandlord(listingId, landlordId) {
      return listingId != null
        && landlordId != null
        && get(/databases/$(database)/documents/listings/$(listingId)).data.landlordId == landlordId;
    }

    function isUniqueViewIncrement() {
      let currentViews = resource.data.uniqueViewCount is int ? resource.data.uniqueViewCount : 0;
      let changedKeys = request.resource.data.diff(resource.data).changedKeys();
      return changedKeys.hasOnly(["uniqueViewCount"])
        && request.resource.data.uniqueViewCount == currentViews + 1;
    }

    function isStatusToggleOnly() {
      let changedKeys = request.resource.data.diff(resource.data).changedKeys();
      return changedKeys.hasOnly(["status", "updatedAt"]);
    }

    function isReviewSummaryUpdate() {
      let changedKeys = request.resource.data.diff(resource.data).changedKeys();
      return changedKeys.hasOnly(["reviewSummary"]);
    }

    function isLandlordAvailabilityMetadataUpdate() {
      let changedKeys = request.resource.data.diff(resource.data).changedKeys();
      return changedKeys.hasOnly(["currentOccupancy", "hasAvailableSlots", "genderPolicy"]);
    }

    function isTenantOccupancyMetadataUpdate(listingId) {
      let changedKeys = request.resource.data.diff(resource.data).changedKeys();
      let tenancyId = listingId + "_" + request.auth.uid;
      let tenancyDoc = get(/databases/$(database)/documents/tenancies/$(tenancyId));
      let tenancyStatus = tenancyDoc.data.status is string ? tenancyDoc.data.status : "";
      return changedKeys.hasOnly(["currentOccupancy", "hasAvailableSlots"])
        && tenancyDoc.exists()
        && tenancyDoc.data.listingId == listingId
        && (tenancyStatus == "signed" || tenancyStatus == "confirmed" || tenancyStatus == "needs_resign" || tenancyStatus == "active");
    }

    function hasTenancyOnListing(listingId) {
      return listingId != null
        && exists(/databases/$(database)/documents/tenancies/$(listingId + "_" + request.auth.uid));
    }

    // Raw analytics events: clients can write, but never read.
    match /events/{eventId} {
      allow create: if isSignedIn() && !isBanned();
      allow read, update, delete: if false;
    }

    // Daily listing stats: landlords can read and write their own stats (e.g. seed data when using emulator without Functions).
    match /listing_daily_stats/{listingId} {
      match /days/{date} {
        allow read, create, update: if isLandlordForListing(listingId) && !isBanned();
        allow delete: if false;
      }
    }

    match /listings/{listingId} {
      allow read: if !isBanned() && (
          isAdmin()
          || (isSignedIn() && resource.data.landlordId == request.auth.uid)
          || (isSignedIn() && isListingReadableByTenant(resource.data))
        );
      allow create: if isSignedIn()
        && !isBanned()
        && request.resource.data.landlordId == request.auth.uid
        && request.resource.data.status == "under_review"
        && request.resource.data.genderPolicy in ["female", "male", "any"];
      allow update: if isSignedIn() && !isBanned() && (
          isAdmin()
          || isUniqueViewIncrement()
          || isReviewSummaryUpdate()
          || (isLandlordForListing(listingId) && isLandlordAvailabilityMetadataUpdate())
          || isTenantOccupancyMetadataUpdate(listingId)
          || (
            isLandlordForListing(listingId)
            && (
              request.resource.data.status == "under_review"
              || (
                isStatusToggleOnly()
                && resource.data.status in ["active", "inactive"]
                && request.resource.data.status in ["active", "inactive"]
              )
            )
          )
        );
      allow delete: if isSignedIn() && !isBanned() && (isLandlordForListing(listingId) || isAdmin());

      match /views/{viewerId} {
        allow read: if isSignedIn()
          && !isBanned()
          && (request.auth.uid == viewerId || isLandlordForListing(listingId));
        allow create: if isSignedIn()
          && !isBanned()
          && request.auth.uid == viewerId
          && request.resource.data.viewerId == viewerId;
        allow update, delete: if false;
      }

      match /reviews/{reviewId} {
        allow read: if (isListingReadableByTenant(get(/databases/$(database)/documents/listings/$(listingId)).data) && !isBanned())
          || isAdmin()
          || isLandlordForListing(listingId)
          || (isSignedIn() && !isBanned() && request.auth.uid == resource.data.reviewerId);
        allow create: if isSignedIn()
          && !isBanned()
          && request.resource.data.listingId == listingId
          && (
            request.auth.uid == request.resource.data.reviewerId
            || (
              isLandlordForListing(listingId)
              && get(/databases/$(database)/documents/listings/$(listingId)).data.isSample == true
              && request.resource.data.reviewerId.matches("^seed_tenant_[1-9][0-9]*$")
            )
          );
        allow update: if isSignedIn()
          && !isBanned()
          && request.auth.uid == resource.data.reviewerId;
        allow delete: if isSignedIn()
          && !isBanned()
          && request.auth.uid == resource.data.reviewerId;
      }
    }

    match /users/{userId} {
      allow read: if isAdmin()
        || (isSignedIn() && request.auth.uid == userId)
        || (isSignedIn() && !isBanned() && resource.data.role == "landlord");
      allow create: if isSignedIn()
        && !isBanned()
        && request.auth.uid == userId
        && (
          (request.resource.data.keys().hasAny(["role"]) && request.resource.data.role in ["tenant", "landlord"])
          || isSampleAdminBootstrap()
        );
      allow update: if isAdmin() || (
          isSignedIn()
          && !isBanned()
          && request.auth.uid == userId
          && !request.resource.data.diff(resource.data).changedKeys().hasAny(["role", "isBanned", "bannedAt", "bannedBy", "banReason"])
        );
      allow delete: if false;

      match /saved_listings/{listingId} {
        allow read, write: if isSignedIn() && !isBanned() && request.auth.uid == userId;
      }
    }

    match /verifications/{userId} {
      allow read: if isSignedIn() && !isBanned() && request.auth.uid == userId;
      allow create: if isSignedIn() && !isBanned() && request.auth.uid == userId;
      allow update: if isSignedIn() && !isBanned() && request.auth.uid == userId;
      allow delete: if false;
    }

    function isChatParticipant(chatData) {
      return isSignedIn()
        && !isBanned()
        && (chatData.tenantId == request.auth.uid || chatData.landlordId == request.auth.uid);
    }

    match /chats/{chatId} {
      allow create: if isSignedIn()
        && !isBanned()
        && request.resource.data.tenantId == request.auth.uid
        && request.resource.data.landlordId != null
        && request.resource.data.listingId != null
        && listingBelongsToLandlord(request.resource.data.listingId, request.resource.data.landlordId);
      allow read, update: if isSignedIn()
        && !isBanned()
        && (resource.data.tenantId == request.auth.uid || resource.data.landlordId == request.auth.uid);
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isSignedIn()
          && !isBanned()
          && (get(/databases/$(database)/documents/chats/$(chatId)).data.tenantId == request.auth.uid
              || get(/databases/$(database)/documents/chats/$(chatId)).data.landlordId == request.auth.uid);
        allow create: if isSignedIn()
          && !isBanned()
          && (get(/databases/$(database)/documents/chats/$(chatId)).data.tenantId == request.auth.uid
              || get(/databases/$(database)/documents/chats/$(chatId)).data.landlordId == request.auth.uid)
          && request.resource.data.senderId == request.auth.uid;
        allow update, delete: if false;
      }
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn() && !isBanned() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn()
        && !isBanned()
        && (
          request.resource.data.userId == request.auth.uid
          || (request.resource.data.listingId != null && isLandlordForListing(request.resource.data.listingId))
        );
      allow update: if isSignedIn() && !isBanned() && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }

    match /aiChats/{userId} {
      allow read: if isSignedIn() && !isBanned() && request.auth.uid == userId;
      allow create: if false;
      allow update, delete: if false;

      match /messages/{messageId} {
        allow read: if isSignedIn() && !isBanned() && request.auth.uid == userId;
        allow create: if isSignedIn()
          && !isBanned()
          && request.auth.uid == userId
          && request.resource.data.userId == userId;
        allow update, delete: if false;
      }
    }

    match /contracts/{contractId} {
      allow read: if isSignedIn()
        && !isBanned()
        && (
          resource.data.tenantId == request.auth.uid
          || resource.data.landlordId == request.auth.uid
          || (
            resource.data.chatId != null
            && isChatParticipant(get(/databases/$(database)/documents/chats/$(resource.data.chatId)).data)
          )
        );
      allow create: if isSignedIn()
        && !isBanned()
        && request.auth.uid == request.resource.data.landlordId
        && request.resource.data.listingId != null
        && request.resource.data.chatId != null
        && request.resource.data.tenantId is string
        && request.resource.data.tenantId.size() > 0
        && listingBelongsToLandlord(request.resource.data.listingId, request.resource.data.landlordId)
        && get(/databases/$(database)/documents/chats/$(request.resource.data.chatId)).data.listingId == request.resource.data.listingId;
      allow update: if isSignedIn()
        && !isBanned()
        && resource.data.keys().hasAll(["tenantId", "landlordId"])
        && (resource.data.tenantId == request.auth.uid || resource.data.landlordId == request.auth.uid)
        && listingBelongsToLandlord(resource.data.listingId, resource.data.landlordId);
      allow delete: if false;
    }

    match /issues/{issueId} {
      allow read: if isSignedIn()
        && !isBanned()
        && (resource.data.tenantId == request.auth.uid || resource.data.landlordId == request.auth.uid);
      allow create: if isSignedIn()
        && !isBanned()
        && request.resource.data.tenantId == request.auth.uid
        && request.resource.data.contractId != null
        && request.resource.data.listingId != null
        && request.resource.data.chatId != null
        && get(/databases/$(database)/documents/contracts/$(request.resource.data.contractId)).data.listingId == request.resource.data.listingId
        && get(/databases/$(database)/documents/contracts/$(request.resource.data.contractId)).data.landlordId == request.resource.data.landlordId
        && get(/databases/$(database)/documents/chats/$(request.resource.data.chatId)).data.listingId == request.resource.data.listingId;
      allow update: if isSignedIn()
        && !isBanned()
        && (resource.data.tenantId == request.auth.uid || resource.data.landlordId == request.auth.uid);
      allow delete: if false;
    }

    match /tenancies/{tenancyId} {
      allow read: if isSignedIn()
        && !isBanned()
        && (
          resource.data.tenantId == request.auth.uid
          || resource.data.landlordId == request.auth.uid
          || (resource.data.listingId != null && isLandlordForListing(resource.data.listingId))
          || (resource.data.listingId != null && hasTenancyOnListing(resource.data.listingId))
        );
      allow create, update: if isSignedIn()
        && !isBanned()
        && (request.resource.data.tenantId == request.auth.uid || request.resource.data.landlordId == request.auth.uid)
        && listingBelongsToLandlord(request.resource.data.listingId, request.resource.data.landlordId)
        && request.resource.data.contractId != null
        && get(/databases/$(database)/documents/contracts/$(request.resource.data.contractId)).data.listingId == request.resource.data.listingId;
      allow delete: if false;
    }

    match /rentals/{rentalId} {
      allow read: if isSignedIn()
        && !isBanned()
        && (resource.data.tenantId == request.auth.uid || resource.data.landlordId == request.auth.uid);
      allow create, update, delete: if false;
    }

    match /ban_appeals/{appealId} {
      allow read: if isAdmin()
        || (isSignedIn() && request.auth.uid == resource.data.userId);
      allow create: if isSignedIn()
        && request.auth.uid == request.resource.data.userId
        && request.resource.data.status == "pending"
        && request.resource.data.reviewedAt == null
        && request.resource.data.reviewedBy == ""
        && request.resource.data.reviewNotes == "";
      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).changedKeys()
          .hasOnly(["status", "reviewedAt", "reviewedBy", "reviewNotes"]);
      allow delete: if false;
    }
  }
}
