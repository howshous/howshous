@startuml System Architecture
!theme plain
skinparam linetype ortho
skinparam rectangle {
    BackgroundColor #E1F5FE
    BorderColor #0277BD
    FontColor #01579B
}
skinparam cloud {
    BackgroundColor #FFF3E0
    BorderColor #E65100
}

package "Mobile Client Layer" {
    rectangle "Android App\n(Kotlin + Jetpack Compose)" as AndroidApp
}

package "Authentication" {
    rectangle "Firebase Auth" as FirebaseAuth
}

package "Backend & Business Logic" {
    rectangle "ViewModels\n(MVVM Pattern)" as ViewModels
    rectangle "Repositories\n(Data Access)" as Repositories
}

package "Data & Storage" {
    rectangle "Firestore Database" as Firestore
    rectangle "Collections:\n- users\n- listings\n- chats\n- messages\n- contracts\n- tenancies\n- rentals\n- issues\n- notifications\n- reviews\n- ban_appeals\n- events\n- listing_daily_stats\n- aiChats\n- saved_listings\n- verifications" as FirestoreCollections
    rectangle "Firebase Storage\n(Listing photos, IDs,\nPermits, Profiles)" as Storage
}

package "Backend Services" {
    rectangle "Cloud Functions\n(TypeScript/Node.js)" as CloudFunctions
}

package "External AI Services" {
    cloud "AI Models" as AIModels {
        rectangle "• Gemini API\n• OpenAI API\n• Groq API" as AIServices
    }
}

package "Local Device Storage" {
    rectangle "DataStore Preferences\n(Session, Role, UID)" as DataStore
}

' Connections
AndroidApp --> FirebaseAuth : authenticate
AndroidApp --> ViewModels : display data
ViewModels --> Repositories : request data
Repositories --> Firestore : CRUD operations
Repositories --> Storage : upload/download files
AndroidApp --> DataStore : persist local state
AndroidApp --> AIModels : query AI models
FirebaseAuth --> Firestore : user management
CloudFunctions --> Firestore : aggregate/sync data
CloudFunctions --> Storage : file operations

note right of AndroidApp
  User Roles:
  • Tenant
  • Landlord
  • Administrator
  • Banned
end note

note right of ViewModels
  ViewModels:
  • HomeViewModel
  • ListingViewModel
  • ChatViewModel
  • AccountViewModel
  • LandlordAnalyticsAIViewModel
  • SignupViewModel
end note

note right of Repositories
  Key Repositories:
  • UserRepository
  • ListingRepository
  • ChatRepository
  • MessageRepository
  • ContractRepository
  • AIChatRepository
  • AnalyticsRepository
  • ListingMetricsRepository
  • SavedListingsRepository
  • IssueRepository
  • BanAppealRepository
end note

@enduml